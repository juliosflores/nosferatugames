{
  "manifest_version": 3,
  "name": "Nosferatu Token Sync",
  "version": "1.0",
  "description": "Sincroniza automaticamente o token do ChatGPT com a VPS Hermes.",
  "permissions": [
    "storage",
    "alarms"
  ],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://hermes.nosferatugames.com.br/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "logo.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "192": "logo.png",
    "512": "logo.png"
  }
}
